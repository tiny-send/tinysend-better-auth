{
  "name": "@tinysend/better-auth",
  "version": "0.2.0",
  "description": "better-auth plugin — sync your users into a tinysend audience (tags + metadata), send auth & security emails, propagate unsubscribes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "tinysend",
    "better-auth",
    "auth",
    "email",
    "verification",
    "magic-link",
    "otp",
    "transactional"
  ],
  "author": "System Operator LLC",
  "license": "MIT",
  "homepage": "https://tinysend.com/developers/better-auth",
  "repository": {
    "type": "git",
    "url": "https://github.com/tiny-send/tinysend-better-auth"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "better-auth": ">=1.0.0",
    "tinysend": ">=0.5.0"
  },
  "devDependencies": {
    "better-auth": "^1.6.19",
    "tinysend": "^0.5.0",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  }
}
